# Price Feed Service Environment
# Deployed to: /etc/quantum/price-feed.env
# Used by: quantum-price-feed.service (EnvironmentFile=-/etc/quantum/price-feed.env)

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
LOGLEVEL=INFO

# WebSocket price feed settings
PRICE_FEED_PUBLISH_INTERVAL_MS=500
# Comma-separated list of symbols to subscribe (empty = use defaults from code)
# PRICE_FEED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

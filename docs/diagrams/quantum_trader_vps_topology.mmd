        BYBIT["Bybit WS"]
        OKX["OKX WS"]
        CGK["CoinGecko /\nFunding Rates"]
    end

    %% ── L0: Edge ──────────────────────────────────────────────────────
    subgraph L0["L0 — Edge (NGINX :80/:443)"]
        NGX["NGINX\nTLS · RateLimit · Proxy\napp.quantumfond.com"]
    end

    %% ── L1: UI & API ──────────────────────────────────────────────────
    subgraph L1["L1 — UI & API"]
        FE["Frontend HTML\n(static)"]
        BE["Backend API\nrun.py :8000"]
        GF["Grafana :3000\n(via /grafana/)"]
    end

    %% ── L2: Data Ingestion ────────────────────────────────────────────
    subgraph L2["L2 — Data Ingestion"]

        TRK["performance-tracker\nbalance-tracker"]
    end

    %% ── L8: Reinforcement Learning ────────────────────────────────────
    subgraph L8["L8 — Reinforcement Learning"]
        RLA["rl-agent\ncontinuous learning"]
        RLT["rl-trainer\npolicy training"]
        RLS["rl-sizer\nsizing model"]
        RLFB["rl-feedback-v2\nweight adjustment"]
        RLMON["rl-monitor\nDiscord alerts"]
    end

    %% ── Observability ─────────────────────────────────────────────────
    subgraph OBS["📊 Observability"]
        PROM["Prometheus :9091"]
        LOKI["Loki :3100"]
        NE["NodeExporter :9100"]
        RE["RedisExporter :9121"]
    end

    %% ── Connections ───────────────────────────────────────────────────

    %% External → L2
    BNW -->|"klines WS"| MP
    BYBIT -->|"WS"| CX
    OKX -->|"WS"| CX
    CGK -->|"REST"| MSF

    %% L2 → Redis
    MP -->|"XADD market.klines"| REDIS
    CX -->|"XADD exchange.normalized"| REDIS
    MSF -->|"XADD market_events"| REDIS

    %% Redis → L3
    REDIS -->|"XREAD market.klines"| AI
    AI -->|"XADD trade.intent"| REDIS
    CEO <-->|"state keys"| REDIS
    MR -->|"SET regime:*"| REDIS

    %% L3 → L4
    REDIS -->|"XREAD trade.intent"| DI
    REDIS -->|"XREAD trade.intent"| AT

    %% L4 → Redis
    DI -->|"refined intents"| REDIS
    AT -->|"XADD trade.intent"| REDIS
    CA -->|"XADD sizing.decided"| REDIS
    HB -->|"XADD harvest.intent"| REDIS

    %% Redis → L5 (governance reads)
    REDIS -->|"reads"| PG
    REDIS -->|"reads"| RS
    REDIS -->|"reads"| EB
    PG -->|"SET governance:policy"| REDIS

    %% Redis → L6
    REDIS -->|"XREAD trade.intent"| EX
    REDIS -->|"XREAD trade.intent"| IB
    REDIS -->|"XREAD panic_close"| EEW

    %% L6 → Exchange
    EX -->|"REST orders"| BNREST
    IE -->|"REST orders"| BNREST

    %% L6 → Redis (results)
    EX -->|"XADD trade.execution.res"| REDIS
    EX -->|"XADD trade.closed"| REDIS
    XMN -->|"XADD panic_close"| REDIS

    %% Redis → L7
    REDIS -->|"XREAD trade.closed"| PI
    REDIS -->|"XREAD trade.closed"| PNLR
    PI -->|"XADD portfolio.state"| REDIS
    PNLR -->|"XADD rl_rewards"| REDIS

    %% Redis → L8
    REDIS -->|"XREAD rl_rewards"| RLT
    RLT -->|"SET rl:policy:*"| REDIS
    RLS -->|"XADD sizing.decided"| REDIS
    RLA <-->|"state keys"| REDIS

    %% NGINX routing
    NGX -->|"/"| FE
    NGX -->|"/api/"| BE
    NGX -->|"/grafana/"| GF
    BE <-->|"Redis r/w"| REDIS

    %% Observability
    PROM --- NE
    PROM --- RE
    PROM --- REDIS
    LOKI -->|"logs"| GF
    PROM -->|"metrics"| GF


        STB["strategy-brain :8011\nper-symbol eval"]
        RKB["risk-brain :8012\nposition sizing"]
        MR["meta-regime\nregime classification"]
        MF["model-federation\nconsensus · voting"]
        MS["model-supervisor :8007\ndrift · governance"]
    end

